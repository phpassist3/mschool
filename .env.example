# Скопируйте этот файл в `.env` и заполните реальными значениями
# перед `docker compose up`.
#
# Compose-файл читает эти переменные — `.env` не коммитим в репозиторий.

# --- Postgres (используется сервисом `db` и собирается в DATABASE_URL) ---
POSTGRES_USER=lms
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lms

# --- API ---
# Случайная строка 32+ символов; JWT, подписанные этим секретом,
# невозможно подделать.
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1d

# Уровень логирования: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Лимит на создание курсов: не более N курсов в скользящем окне (мин).
COURSE_RATE_LIMIT_MAX=3
COURSE_RATE_LIMIT_WINDOW_MINUTES=60

# Порт API на хосте (привязан только к 127.0.0.1).
API_HOST_PORT=3000
